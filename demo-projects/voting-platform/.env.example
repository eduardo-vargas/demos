# Environment Variables for Voting Platform
# Copy this file to .env and fill in your values

# ============================================
# CLOUDFLARE ACCESS (Optional Authentication)
# ============================================

# Your Cloudflare Access team domain
# Found in: Cloudflare Dashboard > Access > Settings > Team Domain
CF_ACCESS_TEAM_DOMAIN=https://your-team.cloudflareaccess.com

# Application Audience (AUD) tag
# Found in: Cloudflare Dashboard > Access > Applications > Your App > Overview > Application Audience
CF_ACCESS_AUD=your-access-aud-tag-here

# ============================================
# APPLICATION SETTINGS
# ============================================

# Application name (used for KV guest tracking)
APP_NAME=voting-platform
